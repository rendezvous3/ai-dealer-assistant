{
  "name": "wine-chat-analytics-dashboard-suite",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "install:all": "npm --prefix api install && npm --prefix ui install",
    "dev:api": "npm --prefix api run dev",
    "dev:ui": "npm --prefix ui run dev -- --host 127.0.0.1 --port 5174",
    "check": "npm --prefix api run check && npm --prefix ui run check",
    "dev:api:remote": "npm --prefix api run dev:remote",
    "dev:api:local": "npm --prefix api run dev:local"
  }
}
